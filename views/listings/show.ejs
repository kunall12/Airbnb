<% layout('/layouts/boilerplate') -%>
    <script>
        const mapToken="<%=process.env.MAP_TOKEN%>";
        const coordinates=<%-JSON.stringify(list.geometry.coordinates)%>;
    </script>
    <div class="container my-4">

        <h2 class="text-center mb-4" style="font-weight:600;">
            <%= list.title %>
        </h2>

        <div class="card  mx-auto listing-card" style="max-width: 520px; border-radius:12px; overflow:hidden;">
            <img src="<%= list.image.url %>" class="card-img-top" alt="Listing image"
                style="height:500px; object-fit:cover;">

            <div class="card-body">
                <h4 class="card-title mb-2"><b>
                    </b></h4>
                <i>
                    <p>Owned by -> <%=list.owner.username%>
                    </p>
                </i>
                <p class="text-muted mb-2">
                    <%= list.description %>
                </p>

                <ul class="list-group mb-3">
                    <li class="list-group-item">
                        <b>Price:</b> &#x20B9; <%= list.price.toLocaleString("en-IN") %> / night
                    </li>
                    <li class="list-group-item">
                        <b>Location:</b>
                        <%= list.location %>
                    </li>
                    <li class="list-group-item">
                        <b>Country:</b>
                        <%= list.country %>
                    </li>
                </ul>
                <%if(currUser && currUser._id.equals(list.owner._id)){%>
                    <div class="d-flex justify-content-between">
                        <a href="/listings/<%= list._id %>/edit" class="btn btn-primary w-50 me-2">Edit</a>

                        <form method="POST" action="/listings/<%= list._id %>?_method=DELETE" class="w-50">
                            <button type="submit" class="btn btn-danger w-100">
                                Delete
                            </button>
                        </form>

                    </div>
                    <%}%>



            </div>


        </div>

        <div class="col-7 offset-3">
            <hr>
            <%if(currUser){%>
                <h4>Add Review... </h4>
                <form method="post" action="/listings/<%= list._id %>/reviews" class="needs-validation" novalidate>
                    <div class="mt-3 mb-3">
                        <label for="rating">Rating</label>
                        <fieldset class="starability-slot">
                            <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1"
                                checked />

                            <input type="radio" id="rate1" name="review[rating]" value="1" />
                            <label for="rate1">1 star</label>

                            <input type="radio" id="rate2" name="review[rating]" value="2" />
                            <label for="rate2">2 stars</label>

                            <input type="radio" id="rate3" name="review[rating]" value="3" />
                            <label for="rate3">3 stars</label>

                            <input type="radio" id="rate4" name="review[rating]" value="4" />
                            <label for="rate4">4 stars</label>

                            <input type="radio" id="rate5" name="review[rating]" value="5" />
                            <label for="rate5">5 stars</label>
                        </fieldset>
                    </div>


                    <div class="mt-3 mb-3">
                        <label for="comment">Comments</label>
                        <textarea name="review[comment]" id="comment" cols="10" rows="5" placeholder="Drop Comments..."
                            class="form-control" required></textarea>
                        <div class="invalid-feedback">Please enter some comment...</div>
                    </div>
                    <button class="btn btn-outline-dark">Submit</button>
                </form>

                <hr>
                <%}%>
                    <%if(list.reviews.length>0){%>
                        <p><b>All Reviews...</b></p>
                        <!-- <p><%=list.reviews%></p> -->
                        <div class="row">
                            <% for (let review of list.reviews) { %>
                                <div class="col-5 mb-4"> <!-- column for 2-per-row layout -->
                                    <div class="card h-100"> <!-- full height cards -->
                                        <div class="card-body">
                                            <h5 class="card-title">@<%=review.author.username%>
                                            </h5>
                                            <p class="starability-result card-text"
                                                data-rating="<%= Number(review.rating) %>">
                                            </p>
                                            <p class="card-text">
                                                <%= review.comment %>
                                            </p>
                                            <form method="post"
                                                action="/listings/<%= list._id %>/reviews/<%=review._id%>?_method=DELETE">
                                                <button class="btn btn-outline-dark btn-sm ">Delete</button>
                                            </form>
                                        </div>
                                    </div>
                                </div>
                                <% } %>
                        </div>
                        <%}%>


        </div>
        <div class="col-7 offset-3">
            <h3>Where you'll be...</h3>
            <div id="map"></div>
        </div>
    </div>

    <script src="/js/map.js"></script>
    